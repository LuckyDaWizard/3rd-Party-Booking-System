# =============================================================================
# .env.example — required environment variables for the 3rd Party Booking System
#
# This file documents the REQUIRED keys (names only). NEVER put real secret
# values here — it is committed to git.
#
# PRODUCTION (VPS): the real values live in
#   /opt/3rd-Party-Booking-System/booking-app/.env
# which is SSH-managed and git-ignored. Docker Compose reads that .env file
# automatically (same directory as docker-compose.yml) for both ${VAR}
# build-args and runtime `environment:` interpolation.
#
# 🚫 Do NOT manage these via the Hostinger Docker Manager "Environment" panel —
#    saving there regenerates docker-compose.yml and wipes the Traefik/HSTS
#    labels. Edit the .env file over SSH instead. See OPERATIONS.md →
#    "Environment variables".
#
# LOCAL DEV: copy this to .env.local (also git-ignored) and fill in dev values.
#
# NOTE: NODE_ENV and PORT are NOT set here — NODE_ENV=production is hardcoded in
# docker-compose.yml and PORT comes from the image.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (production: https://bookings.carefirst.co.za) ---
NEXT_PUBLIC_APP_URL=

# --- SMTP (PIN-reset + notification emails) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- PayFast payment gateway (sandbox during pilot; see project_payfast_mode) ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_TEST_MODE=

# --- CareFirst Patient SSO handoff ---
CAREFIRST_API_DOMAIN=
CAREFIRST_API_KEY=
CAREFIRST_CLIENT_CODE=
CAREFIRST_CLIENT_PLAN_CODE=

# --- Cron auth (VPS crontab → /api/* maintenance routes; X-Cron-Secret) ---
CRON_SECRET=
