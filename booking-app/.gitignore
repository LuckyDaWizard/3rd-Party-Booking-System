# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Lock files from other package managers (we use npm)
yarn.lock
pnpm-lock.yaml
bun.lockb

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
/coverage
/.nyc_output
/test-results
/playwright-report
/playwright/.cache

# ---------------------------------------------------------------------------
# Next.js build output
# ---------------------------------------------------------------------------
/.next/
/out/
next-env.d.ts

# ---------------------------------------------------------------------------
# Production build
# ---------------------------------------------------------------------------
/build
/dist

# ---------------------------------------------------------------------------
# TypeScript build info
# ---------------------------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Env files — NEVER commit secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# Supabase local artefacts
# ---------------------------------------------------------------------------
# Local CLI state (keep migrations/, ignore generated stuff)
.supabase/
supabase/.branches/
supabase/.temp/

# ---------------------------------------------------------------------------
# Logs + debug
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# IDE / editor files
# ---------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.pem
*.bak
*.backup
*.orig
*.tmp
