# =============================================================================
# Root .gitignore
# =============================================================================
# Only the booking-app/ subdirectory is the shippable project. Anything else
# at the root is support material (design files, Claude Code scratch, etc.)
# and should not be in the production repo.
# =============================================================================

# ---------------------------------------------------------------------------
# Project-level non-code artefacts
# ---------------------------------------------------------------------------

# Design mocks, reference images, supporting docs — kept locally only.
Project Files/

# Claude Code / AI tooling scratch — should never be committed.
.claude/

# Ad-hoc test notes.
testing extention.txt

# Stray Next.js build artefacts — if someone accidentally runs `next build`
# or `next dev` from the repo root instead of booking-app/, it creates a
# .next folder here. Ignore so it doesn't pollute commits.
/.next/

# Audit reports — generated locally, may contain sensitive findings.
# Commit only final published versions if needed; drafts stay local.
AUDIT_REPORT_*.md

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------

# Any .env file at the root (defensive — project uses booking-app/.env.local)
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Operating-system files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# IDE / editor files
# ---------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Backup / temporary files
# ---------------------------------------------------------------------------
*.bak
*.backup
*.orig
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# OneDrive conflict artefacts (this repo lives inside a OneDrive folder)
# ---------------------------------------------------------------------------
*-[Cc]onflict*
*- conflicted copy*
